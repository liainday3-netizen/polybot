# ═══════════════════════════════════════════════════════════════
# POLYBOT — Configuration
# ═══════════════════════════════════════════════════════════════

# Your wallet's private key (NEVER share this!)
POLYMARKET_PK=0xYOUR_PRIVATE_KEY_HERE

# Your wallet's public address
POLYMARKET_FUNDER=0xYOUR_WALLET_ADDRESS_HERE

# API credentials (generated by setup_credentials.py)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Target wallets to copy (comma-separated)
TARGET_WALLETS=0xWallet1,0xWallet2,0xWallet3

# ═══════════════════════════════════════════════════════════════
# CAPITAL SETTINGS
# ═══════════════════════════════════════════════════════════════
TOTAL_USDC=15.0
POL_RESERVE=10.0

# ═══════════════════════════════════════════════════════════════
# RISK SETTINGS
# ═══════════════════════════════════════════════════════════════
MAX_PER_TRADE_PCT=15
MAX_OPEN_POSITIONS=5
STOP_LOSS_PCT=40
TAKE_PROFIT_PCT=80
DAILY_LOSS_LIMIT=8.0
MIN_SIGNAL_SIZE=5.0

# ═══════════════════════════════════════════════════════════════
# COPY SETTINGS
# ═══════════════════════════════════════════════════════════════
COPY_SCALE_FACTOR=10
COPY_DELAY_SECONDS=3
MONITOR_INTERVAL=30
POSITION_CHECK_INTERVAL=15

# ═══════════════════════════════════════════════════════════════
# AUTO-SCALING
# ═══════════════════════════════════════════════════════════════
AUTO_SCALE_UP_PCT=15
AUTO_SCALE_WINS_REQUIRED=2

# ═══════════════════════════════════════════════════════════════
# MEV PROTECTION
# ═══════════════════════════════════════════════════════════════
MEV_PROTECTION=true
PRIVATE_RPC=https://rpc-mainnet.private.polygon.technology
PUBLIC_RPC=https://polygon-rpc.com

# ═══════════════════════════════════════════════════════════════
# POLYMARKET NETWORK
